# Токен бота от @BotFather (обязательно)
TELEGRAM_BOT_TOKEN=

# API-ключ TronGrid с https://www.trongrid.io (опционально — без него тоже работает,
# но с ключом выше лимиты запросов)
TRONGRID_API_KEY=

# Whitelist: Telegram ID через запятую, например: 123456789,987654321
# Всем, кого нет в списке, бот отказывает и показывает их ID.
# Правки этой строки бот подхватывает сам примерно за минуту — перезапуск
# не нужен; добавленному пользователю бот напишет, что доступ открыт.
ALLOWED_USER_IDS=

# Кошелёк каждый пользователь задаёт себе сам командой /wallet (бот спросит
# адрес). Хранятся в wallets.json рядом с ботом (только публичные адреса).

# Платёжный TRX-адрес сервиса аренды энергии (куда отправляешь 1.5/3 TRX).
# Возьми его из бота аренды, которым пользуешься.
ENERGY_SERVICE_PAYMENT_ADDRESS=

# Адрес автоматического обмена USDT -> TRX того же сервиса (опционально).
# Когда на кошельке мало TRX для оплаты аренды, бот подскажет этот обмен.
EXCHANGE_PAYMENT_ADDRESS=

# Адрес страницы-мостика: выложи bridge/index.html на любой https-хостинг
# (Cloudflare, GitHub Pages — см. README) и впиши сюда её адрес, например
# https://tron-bridge.имя.workers.dev
# Тогда бот будет присылать кнопку «Открыть в TronLink» и QR.
# Пусто — бот даёт адрес и сумму просто текстом для копирования.
BRIDGE_BASE_URL=

# Предупреждать «запас TRX тает», когда на кошельке меньше стольких TRX
# (30 - примерно девять переводов по двойному тарифу, с запасом).
TRX_LOW_BALANCE_WARN=30

# Деплой на свой сервер (используется deploy.sh, бот эти строки не читает):
# IP/хост сервера и путь к ssh-ключу.
DEPLOY_HOST=
DEPLOY_KEY=
